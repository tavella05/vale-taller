generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  email      String   @unique
  firstName  String   @default("") @map("first_name")
  lastName   String   @default("") @map("last_name")
  password   String
  role       String   @default("customer")
  phone      String   @default("")
  dni        String   @default("")
  isActive   Boolean  @default(true) @map("is_active")
  dateJoined DateTime @default(now()) @map("date_joined")

  appointments   Appointment[]
  stockMovements StockMovement[]
  injectorWorks  InjectorWork[]  @relation("CustomerWorks")
  assignedWorks  InjectorWork[]  @relation("AssignedWorks")

  @@map("users")
}

model Service {
  id              Int         @id @default(autoincrement())
  name            String
  description     String      @default("") @db.Text
  serviceType     String      @default("keys") @map("service_type")
  durationMinutes Int         @default(30) @map("duration_minutes")
  price           Decimal     @default(0) @db.Decimal(10, 2)
  isActive        Boolean     @default(true) @map("is_active")

  appointments Appointment[]

  @@map("services")
}

model WorkingHours {
  id           Int     @id @default(autoincrement())
  dayOfWeek    Int     @unique @map("day_of_week")
  isOpen       Boolean @default(true) @map("is_open")
  openTime     String  @default("09:00") @map("open_time")
  closeTime    String  @default("18:00") @map("close_time")
  slotDuration Int     @default(30) @map("slot_duration")

  @@map("working_hours")
}

model Appointment {
  id           Int      @id @default(autoincrement())
  customerId   Int      @map("customer_id")
  serviceId    Int      @map("service_id")
  date         String
  time         String
  status       String   @default("pending")
  vehicleMake  String   @default("") @map("vehicle_make")
  vehicleModel String   @default("") @map("vehicle_model")
  vehicleYear  Int?     @map("vehicle_year")
  notes        String   @default("") @db.Text
  staffNotes   String   @default("") @map("staff_notes") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  customer User    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service  Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@map("appointments")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  description String    @default("")

  products Product[]

  @@map("categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  categoryId  Int      @map("category_id")
  name        String
  description String   @default("") @db.Text
  sku         String   @unique @default("")
  price       Decimal  @default(0) @db.Decimal(10, 2)
  stock       Int      @default(0)
  minStock    Int      @default(5) @map("min_stock")
  image       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category  Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  movements StockMovement[]

  @@map("products")
}

model StockMovement {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  movementType String   @map("movement_type")
  quantity     Int
  reason       String   @default("")
  createdAt    DateTime @default(now()) @map("created_at")
  createdById  Int?     @map("created_by_id")

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@map("stock_movements")
}

model InjectorPart {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("") @db.Text
  partNumber  String   @default("") @map("part_number")
  stock       Int      @default(0)
  minStock    Int      @default(2) @map("min_stock")
  price       Decimal  @default(0) @db.Decimal(10, 2)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  workUsages WorkPartUsage[]

  @@map("injector_parts")
}

model InjectorWork {
  id               Int       @id @default(autoincrement())
  customerName     String    @map("customer_name")
  customerPhone    String    @map("customer_phone")
  customerEmail    String    @default("") @map("customer_email")
  customerId       Int?      @map("customer_id")
  vehicleMake      String    @map("vehicle_make")
  vehicleModel     String    @map("vehicle_model")
  vehicleYear      Int?      @map("vehicle_year")
  injectorQuantity Int       @default(1) @map("injector_quantity")
  diagnosis        String    @default("") @db.Text
  workDone         String    @default("") @map("work_done") @db.Text
  status           String    @default("received")
  price            Decimal   @default(0) @db.Decimal(10, 2)
  receivedAt       DateTime  @default(now()) @map("received_at")
  completedAt      DateTime? @map("completed_at")
  assignedToId     Int?      @map("assigned_to_id")
  notes            String    @default("") @db.Text

  customer   User?          @relation("CustomerWorks", fields: [customerId], references: [id], onDelete: SetNull)
  assignedTo User?          @relation("AssignedWorks", fields: [assignedToId], references: [id], onDelete: SetNull)
  partsUsed  WorkPartUsage[]

  @@map("injector_works")
}

model WorkPartUsage {
  id       Int @id @default(autoincrement())
  workId   Int @map("work_id")
  partId   Int @map("part_id")
  quantity Int @default(1)

  work InjectorWork @relation(fields: [workId], references: [id], onDelete: Cascade)
  part InjectorPart @relation(fields: [partId], references: [id], onDelete: Restrict)

  @@map("work_part_usages")
}
